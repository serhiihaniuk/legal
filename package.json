{
  "name": "legalizacja-atlas",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "corpus:kpa": "node scripts/legal-corpus/build-document.mjs legal-corpus/documents/kpa-2025-1691.json",
    "corpus:build": "node scripts/legal-corpus/build-document.mjs",
    "corpus:prepare": "node scripts/legal-corpus/workflow.mjs prepare",
    "corpus:validate": "node scripts/legal-corpus/workflow.mjs validate",
    "corpus:diff": "node scripts/legal-corpus/workflow.mjs diff",
    "corpus:generate": "node scripts/legal-corpus/generate-registry.mjs",
    "corpus:promote": "node scripts/legal-corpus/workflow.mjs promote",
    "test:corpus": "node --test scripts/legal-corpus/test/*.test.mjs",
    "test:editorial": "node scripts/legal-editorial/validate.mjs",
    "test:previews": "node scripts/reference-previews/validate.mjs",
    "test": "vitest run",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json",
    "lint": "oxlint",
    "format": "prettier --write \"**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@react-router/node": "7.15.1",
    "@react-router/serve": "7.15.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "isbot": "^5",
    "lucide-react": "^1.24.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "7.15.1",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@react-router/dev": "7.15.1",
    "@tailwindcss/vite": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "happy-dom": "^20.10.6",
    "oxlint": "^1.74.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "typescript": "^6",
    "vite": "^8",
    "vitest": "^4.1.10"
  }
}
